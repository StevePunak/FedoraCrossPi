[Unit]
Description=Expand root filesystem to fill SD card
DefaultDependencies=no
Before=local-fs-pre.target
After=systemd-remount-fs.service
ConditionPathExists=/usr/sbin/expand-rootfs.sh

[Service]
Type=oneshot
ExecStart=/usr/sbin/expand-rootfs.sh
RemainAfterExit=yes

[Install]
WantedBy=local-fs.target
